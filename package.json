{
	"name": "@cego/gitte",
	"version": "1.4.1",
	"description": "Git automation and action execution across a list of projects",
	"main": "bin/main.js",
	"bin": {
		"gitte": "bin/main.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cego/gitte.git"
	},
	"keywords": [
		"git",
		"automation",
		"action",
		"execution",
		"microservice"
	],
	"author": "Mads Jon Nielsen <madsjon@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/cego/gitte/issues"
	},
	"homepage": "https://github.com/cego/gitte#readme",
	"dependencies": {
		"@yao-pkg/pkg": "^6.11.0",
		"ajv": "8.17.1",
		"ansi-escapes": "7.2.0",
		"await-to-js": "3.0.0",
		"chalk": "5.6.2",
		"cli-progress": "3.12.0",
		"death": "1.1.0",
		"dotenv": "17.2.3",
		"execa": "9.6.1",
		"fs-extra": "11.3.3",
		"js-yaml": "4.1.1",
		"lodash": "4.17.21",
		"prompts": "2.4.2",
		"source-map-support": "0.5.21",
		"tildify": "3.0.0",
		"yargs": "18.0.0"
	},
	"devDependencies": {
		"@types/ansi-escape-sequences": "4.0.4",
		"@types/cli-progress": "3.11.6",
		"@types/death": "1.1.5",
		"@types/fs-extra": "11.0.4",
		"@types/jest": "30.0.0",
		"@types/jest-when": "3.5.5",
		"@types/js-yaml": "4.0.9",
		"@types/lodash": "4.17.21",
		"@types/node": "25.0.3",
		"@types/prompts": "2.4.9",
		"@types/yargs": "17.0.35",
		"@typescript-eslint/eslint-plugin": "8.51.0",
		"@typescript-eslint/parser": "8.51.0",
		"eslint": "9.39.2",
		"eslint-config-prettier": "10.1.8",
		"jest": "30.2.0",
		"jest-when": "3.7.0",
		"prettier": "3.7.4",
		"ts-jest": "29.4.6",
		"ts-node": "10.9.2",
		"typescript": "5.9.3"
	},
	"scripts": {
		"eslint": "eslint . --max-warnings=0",
		"prettier": "prettier -c .",
		"prettier:fix": "prettier -c --write .",
		"lint": "npm run eslint && npm run prettier",
		"lint:fix": "npm run eslint && npm run prettier:fix",
		"build": "rm -f src/*.js src/*.d.ts && tsc",
		"test": "jest",
		"test:coverage": "jest --coverage"
	},
	"pkg": {
		"assets": [
			"package.json"
		],
		"scripts": [
			"bin/**/*.js",
			"src/**/*.js"
		]
	}
}
